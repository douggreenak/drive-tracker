generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trip {
  id            String       @id @default(cuid())
  date          DateTime     @default(now())
  startAddress  String
  endAddress    String
  startLat      Float
  startLng      Float
  endLat        Float
  endLng        Float
  distance      Float
  duration      Int
  notes         String?
  routeEncoded  String?
  category      TripCategory @default(OTHER)
  isFavorite    Boolean      @default(false)
  // Who covers this drive's fuel — the app's core "who pays for gas" concept, mirrored from iOS.
  paidBy        PaidBy       @default(SELF)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  gasEntries    GasEntry[]

  @@index([date])
  @@index([category])
  @@index([isFavorite])
  @@index([paidBy])
}

model GasEntry {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  gallons        Float
  pricePerGallon Float
  totalCost      Float
  paidBy         PaidBy
  fuelType       FuelType @default(REGULAR)
  stationName    String?
  odometer       Float?
  vehicleName    String?
  tripId         String?
  trip           Trip?    @relation(fields: [tripId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
  @@index([paidBy])
  @@index([tripId])
}

model Vehicle {
  id        String   @id @default(cuid())
  name      String
  make      String?
  model     String?
  year      Int?
  tankSize  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id            String @id @default(cuid())
  monthlyBudget Float  @default(0)
  distanceUnit  String @default("miles")
  currency      String @default("USD")
  theme         String @default("system")
}

// Mirror of the iOS ScheduledDrive (the phone is the source of truth; this is a best-effort copy
// so the web dashboard can show and manage the schedule).
model ScheduledDrive {
  id                  String       @id @default(cuid())
  title               String
  startAddress        String
  endAddress          String
  startLat            Float
  startLng            Float
  endLat              Float
  endLng              Float
  departure           DateTime
  estimatedTravelTime Int
  scheduledArrival    DateTime
  repeatRule          RepeatRule   @default(NONE)
  category            TripCategory @default(COMMUTE)
  paidBy              PaidBy       @default(SELF)
  vehicleName         String?
  notes               String?
  isEnabled           Boolean      @default(true)
  isCanceled          Boolean      @default(false)
  lastStartedAt       DateTime?
  lastCompletedAt     DateTime?
  // Occurrences the user deleted "just this once", as epoch seconds.
  skippedOccurrences  Float[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([departure])
  @@index([isCanceled])
}

enum PaidBy {
  SELF
  PARENTS
}

enum TripCategory {
  COMMUTE
  ERRAND
  ROAD_TRIP
  SCHOOL
  WORK
  LEISURE
  OTHER
}

enum FuelType {
  REGULAR
  MIDGRADE
  PREMIUM
  DIESEL
}

enum RepeatRule {
  NONE
  DAILY
  WEEKDAYS
  WEEKLY
}
